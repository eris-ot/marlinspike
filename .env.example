DB_PASSWORD=change-me
SECRET_KEY=change-me
ADMIN_PASSWORD=change-me
PORT=5001
HOST=0.0.0.0
SESSION_COOKIE_SECURE=true
# Leave blank for single-process dev. Docker Compose defaults this to the
# bundled Redis service unless you override it.
RATELIMIT_STORAGE_URI=
PCAP_MAX_SIZE=5368709120
PCAP_PROCESS_SIZE=5368709120
MARLINSPIKE_DPI_REPO=https://github.com/eris-ot/marlinspike-dpi.git
MARLINSPIKE_DPI_REF=326bdbb744a7b8f71295381fd209d9587dc09a3b
MARLINSPIKE_MITRE_REPO=https://github.com/eris-ot/marlinspike-mitre.git
MARLINSPIKE_MITRE_REF=c3583ec2d189b8cde69f2160da6a5e8e5b643f7b
# Optional Stage 4b IOC engine. Leave MARLINSPIKE_MALWARE_REPO empty to skip bundling it.
MARLINSPIKE_MALWARE_REPO=https://github.com/eris-ot/marlinspike-malware.git
MARLINSPIKE_MALWARE_REF=4a008211cad7e56609e8a667b95f1c09b790c1b4
MARLINSPIKE_MALWARE_RULES_REPO=https://github.com/eris-ot/marlinspike-malware-rules.git
MARLINSPIKE_MALWARE_RULES_REF=99cbe9358d0a5047d9b5e57a7e4ff5eafdee9bd4

# CISA KEV + ICS advisory enrichment. Bundled plugin; no external repo needed.
# Disable to skip the CISA stage after each scan. Refresh the catalog with:
#   python3 plugins/marlinspike_cisa/../../scripts/sync_cisa_catalog.py
MARLINSPIKE_CISA_ENABLED=true
MARLINSPIKE_CISA_MODULE=plugins.marlinspike_cisa

# Live capture (optional, Linux only). See docs/live-capture.md.
# Set ENABLED=true and bring up the capd sidecar to enable.
LIVE_CAPTURE_ENABLED=false
LIVE_CAPTURE_SOCKET=/var/run/marlinspike-capd/marlinspike-capd.sock
LIVE_CAPTURE_TIMEOUT_S=5
LIVE_CAPTURE_MAX_CONCURRENT=2
# uid the capd uds socket will accept; defaults to root if unset.
# In compose, set this to the uid the app container runs as.
LIVE_CAPTURE_ALLOW_UID=0
